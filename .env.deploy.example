# 部署环境变量配置示例
# 复制此文件为 .env.deploy 并填入真实值，请勿将真实值提交到 Git

DEPLOY_HOST=your_server_ip
DEPLOY_USER=your_ssh_user
DEPLOY_SSH_KEY_PATH=your_ssh_key_path
DEPLOY_PROJECT_DIR=your_project_dir
DEPLOY_PM2_SERVER=your_pm2_server_name
DEPLOY_PM2_ADMIN=your_pm2_admin_name
DEPLOY_HEALTH_URL_SERVER=your_server_health_url
DEPLOY_HEALTH_URL_ADMIN=your_admin_health_url
ZHIPU_API_KEY_2=your_zhipu_api_key
