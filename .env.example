# DeepMindMap 环境变量配置示例
# 使用说明：复制本文件为 .env 并填入真实值，切勿将 .env 提交到版本控制
# cp .env.example .env

# ============================================
# MongoDB 配置
# ============================================
# MongoDB root 用户密码（docker-compose.yml 中 MONGO_INITDB_ROOT_PASSWORD 引用）
MONGO_PASSWORD=your_secure_password_here

# ============================================
# Neo4j 配置
# ============================================
# Neo4j 数据库密码（docker-compose.yml 中 NEO4J_AUTH 引用）
NEO4J_PASSWORD=your_secure_password_here

# ============================================
# 其他数据库相关配置
# ============================================
# 如需扩展更多数据库相关配置，请在下方补充
