# 后端 API 地址
VITE_API_URL=

# 极光推送 AppKey（Capacitor 配置读取 VITE_ 前缀变量）
# 注意：请勿在此填写真实密钥后提交；真实值应通过 CI Secret 或本地 .env.mobile 注入。
VITE_JPUSH_APPKEY=

# Android Gradle 构建使用的极光推送配置（与 manifestPlaceholders 对应）
JPUSH_APPKEY=
JPUSH_CHANNEL=default

# Android Release 签名占位（可选，仅正式打包时需要）
# KEYSTORE_PATH=./release.keystore
# KEYSTORE_ALIAS=release
# KEYSTORE_PASSWORD=
# KEYSTORE_ALIAS_PASSWORD=
