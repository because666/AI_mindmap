# DeepMindMap Server Configuration
# Copy this file to .env and update the values as needed

# Server Configuration
PORT=3001
HOST=localhost

# Neo4j Configuration
# Using Docker Compose defaults:
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here
NEO4J_DATABASE=neo4j

# MongoDB Configuration
# Using Docker Compose defaults:
MONGODB_URI=mongodb://your-db-user:your-db-password@localhost:27017/deepmindmap?authSource=admin
MONGODB_DATABASE=deepmindmap

# Vector Database Configuration
# Options: memory, pinecone, weaviate
VECTOR_PROVIDER=memory
VECTOR_DIMENSION=1536
VECTOR_INDEX=deepmindmap_vectors

# AI Configuration
# Default provider: zhipu, openai, anthropic
DEFAULT_PROVIDER=zhipu

# Zhipu AI Configuration (default)
# Get your API key from: https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key-here
# 智谱AI第二个API Key（可选，配置后支持Key轮询提升并发能力）
ZHIPU_API_KEY_2=
DEFAULT_MODEL=glm-4-flash

# OpenAI Configuration (optional)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-3-small

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# JPush Configuration (极光推送配置)
JPUSH_APPKEY=your-jpush-appkey-here
JPUSH_MASTER_SECRET=your-jpush-master-secret-here
PUSH_FORCE_READ_DAYS=7
PUSH_MESSAGE_RETENTION_DAYS=30
PUSH_BROADCAST_BATCH_SIZE=1000

# Scheduled Jobs Configuration (定时任务开关)
ENABLE_WORKSPACE_STATS_JOB=true
ENABLE_CLEANUP_JOB=true

# CORS Configuration (允许的跨域来源，多个用逗号分隔，为空时开发环境默认允许localhost)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Internal API Token (Admin后台与主服务端通信密钥)
INTERNAL_API_TOKEN=your-internal-api-token-here

# System Prompt (AI对话全局系统提示词，为空时使用内置默认提示词)
SYSTEM_PROMPT=

# SMTP Email Configuration (反馈邮件发送)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-authorization-code
FEEDBACK_EMAIL=your-email@qq.com
